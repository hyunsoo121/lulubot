generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// 유저 & 계정
// ─────────────────────────────────────────

model User {
  id            BigInt   @id @default(autoincrement())
  discordUserId BigInt?  @unique @map("discord_user_id")
  createdAt     DateTime @default(now()) @map("created_at")

  lolAccounts      LolAccount[]
  userGuildServers UserGuildServer[]

  @@map("user")
}

model LolAccount {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @map("user_id")
  puuid     String   @unique @db.VarChar(78)
  gameName  String   @map("game_name") @db.VarChar(100)
  tagLine   String   @map("tag_line") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  tournamentCodes  TournamentCode[]
  playerMatchStats PlayerMatchStat[]
  userServerStats  UserServerStat[]
  userGlobalStat   UserGlobalStat?
  championStats    ChampionStat[]
  positionStats    PositionStat[]
  duoStatsAs1      DuoStat[]         @relation("DuoAccount1")
  duoStatsAs2      DuoStat[]         @relation("DuoAccount2")
  userAchievements UserAchievement[]
  userTitles       UserTitle[]

  @@map("lol_account")
}

// ─────────────────────────────────────────
// 서버
// ─────────────────────────────────────────

model GuildServer {
  id            BigInt   @id
  serverName    String?  @map("server_name") @db.VarChar(100)
  isWhitelisted Boolean  @default(false) @map("is_whitelisted")
  createdAt     DateTime @default(now()) @map("created_at")

  userGuildServers UserGuildServer[]
  tournamentCodes  TournamentCode[]
  matchRecords     MatchRecord[]
  userServerStats  UserServerStat[]
  championStats    ChampionStat[]
  positionStats    PositionStat[]
  duoStats         DuoStat[]
  userTitles       UserTitle[]

  @@map("guild_server")
}

model UserGuildServer {
  userId        BigInt   @map("user_id")
  guildServerId BigInt   @map("guild_server_id")
  joinedAt      DateTime @default(now()) @map("joined_at")

  user        User        @relation(fields: [userId], references: [id])
  guildServer GuildServer @relation(fields: [guildServerId], references: [id])

  @@id([userId, guildServerId])
  @@map("user_guild_server")
}

// ─────────────────────────────────────────
// 토너먼트 & 매치
// ─────────────────────────────────────────

model TournamentCode {
  id            BigInt               @id @default(autoincrement())
  code          String               @unique @db.VarChar(100)
  guildServerId BigInt               @map("guild_server_id")
  issuedBy      BigInt               @map("issued_by")
  status        TournamentCodeStatus @default(PENDING)
  createdAt     DateTime             @default(now()) @map("created_at")
  expiredAt     DateTime?            @map("expired_at")

  guildServer GuildServer  @relation(fields: [guildServerId], references: [id])
  lolAccount  LolAccount   @relation(fields: [issuedBy], references: [id])
  matchRecord MatchRecord?

  @@map("tournament_code")
}

model MatchRecord {
  id               BigInt    @id @default(autoincrement())
  matchId          String    @unique @map("match_id") @db.VarChar(50)
  guildServerId    BigInt?   @map("guild_server_id")   // NULL = 글로벌 스캔 매치
  tournamentCodeId BigInt?   @unique @map("tournament_code_id")
  winnerTeam       Team      @map("winner_team")
  gameDurationSecs Int       @map("game_duration_secs")
  playedAt         DateTime  @map("played_at")

  guildServer    GuildServer?      @relation(fields: [guildServerId], references: [id])
  tournamentCode TournamentCode?   @relation(fields: [tournamentCodeId], references: [id])
  playerStats    PlayerMatchStat[]

  @@map("match_record")
}

model PlayerMatchStat {
  id                 BigInt  @id @default(autoincrement())
  matchId            BigInt  @map("match_id")
  lolAccountId       BigInt  @map("lol_account_id")
  team               Team
  championId         Int     @map("champion_id")
  position           String  @db.VarChar(20)
  kills              Int
  deaths             Int
  assists            Int
  cs                 Int
  damageDealt        Int     @map("damage_dealt")
  damageTaken        Int     @map("damage_taken")
  goldEarned         Int     @map("gold_earned")
  visionScore        Int     @map("vision_score")
  isWin              Boolean @map("is_win")
  killParticipation  Float   @default(0) @map("kill_participation")
  turretKills        Int     @default(0) @map("turret_kills")
  firstBloodKill     Boolean @default(false) @map("first_blood_kill")
  pentaKills         Int     @default(0) @map("penta_kills")
  quadraKills        Int     @default(0) @map("quadra_kills")
  dragonKills        Int     @default(0) @map("dragon_kills")
  baronKills         Int     @default(0) @map("baron_kills")
  wardsPlaced        Int     @default(0) @map("wards_placed")
  wardsKilled        Int     @default(0) @map("wards_killed")
  controlWardsPlaced Int     @default(0) @map("control_wards_placed")
  dmgShare           Float   @default(0) @map("dmg_share")
  goldShare          Float   @default(0) @map("gold_share")
  dmgPerGold         Float   @default(0) @map("dmg_per_gold")
  timeCCingOthers    Int     @default(0) @map("time_ccing_others")
  enemyJungleMinions Int     @default(0) @map("enemy_jungle_minions")
  objectivesStolen   Int     @default(0) @map("objectives_stolen")
  healsOnTeammates   Int     @default(0) @map("heals_on_teammates")
  shieldOnTeammates  Int     @default(0) @map("shield_on_teammates")
  soloKills          Int     @default(0) @map("solo_kills")

  matchRecord MatchRecord @relation(fields: [matchId], references: [id])
  lolAccount  LolAccount  @relation(fields: [lolAccountId], references: [id])

  @@map("player_match_stat")
}

// ─────────────────────────────────────────
// 통계
// ─────────────────────────────────────────

model UserServerStat {
  id               BigInt   @id @default(autoincrement())
  lolAccountId     BigInt   @map("lol_account_id")
  guildServerId    BigInt   @map("guild_server_id")
  totalGames       Int      @default(0) @map("total_games")
  totalWins        Int      @default(0) @map("total_wins")
  totalKills       Int      @default(0) @map("total_kills")
  totalDeaths      Int      @default(0) @map("total_deaths")
  totalAssists     Int      @default(0) @map("total_assists")
  totalDamage      BigInt   @default(0) @map("total_damage")
  totalVisionScore Int      @default(0) @map("total_vision_score")
  pentaKillCount   Int      @default(0) @map("penta_kill_count")
  currentStreak    Int      @default(0) @map("current_streak")
  updatedAt        DateTime @updatedAt @map("updated_at")

  lolAccount  LolAccount  @relation(fields: [lolAccountId], references: [id])
  guildServer GuildServer @relation(fields: [guildServerId], references: [id])

  @@unique([lolAccountId, guildServerId])
  @@map("user_server_stat")
}

// 전체 서버 합산 누적 통계 (커스텀 게임 전체 기반)
model UserGlobalStat {
  id               BigInt   @id @default(autoincrement())
  lolAccountId     BigInt   @unique @map("lol_account_id")
  totalGames       Int      @default(0) @map("total_games")
  totalWins        Int      @default(0) @map("total_wins")
  totalKills       Int      @default(0) @map("total_kills")
  totalDeaths      Int      @default(0) @map("total_deaths")
  totalAssists     Int      @default(0) @map("total_assists")
  totalDamage      BigInt   @default(0) @map("total_damage")
  totalVisionScore Int      @default(0) @map("total_vision_score")
  pentaKillCount   Int      @default(0) @map("penta_kill_count")
  updatedAt        DateTime @updatedAt @map("updated_at")

  lolAccount LolAccount @relation(fields: [lolAccountId], references: [id])

  @@map("user_global_stat")
}

model ChampionStat {
  id            BigInt @id @default(autoincrement())
  lolAccountId  BigInt @map("lol_account_id")
  guildServerId BigInt @map("guild_server_id")
  championId    Int    @map("champion_id")
  totalGames    Int    @default(0) @map("total_games")
  totalWins     Int    @default(0) @map("total_wins")
  totalKills    Int    @default(0) @map("total_kills")
  totalDeaths   Int    @default(0) @map("total_deaths")
  totalAssists  Int    @default(0) @map("total_assists")

  lolAccount  LolAccount  @relation(fields: [lolAccountId], references: [id])
  guildServer GuildServer @relation(fields: [guildServerId], references: [id])

  @@unique([lolAccountId, guildServerId, championId])
  @@map("champion_stat")
}

model PositionStat {
  id            BigInt @id @default(autoincrement())
  lolAccountId  BigInt @map("lol_account_id")
  guildServerId BigInt @map("guild_server_id")
  position      String @db.VarChar(20)
  totalGames    Int    @default(0) @map("total_games")
  totalWins     Int    @default(0) @map("total_wins")
  totalKills    Int    @default(0) @map("total_kills")
  totalDeaths   Int    @default(0) @map("total_deaths")
  totalAssists  Int    @default(0) @map("total_assists")

  lolAccount  LolAccount  @relation(fields: [lolAccountId], references: [id])
  guildServer GuildServer @relation(fields: [guildServerId], references: [id])

  @@unique([lolAccountId, guildServerId, position])
  @@map("position_stat")
}

model DuoStat {
  id            BigInt @id @default(autoincrement())
  guildServerId BigInt @map("guild_server_id")
  lolAccountId1 BigInt @map("lol_account_id_1")
  lolAccountId2 BigInt @map("lol_account_id_2")
  sameTeamGames Int    @default(0) @map("same_team_games")
  sameTeamWins  Int    @default(0) @map("same_team_wins")
  againstGames  Int    @default(0) @map("against_games")
  againstWins   Int    @default(0) @map("against_wins")

  guildServer GuildServer @relation(fields: [guildServerId], references: [id])
  lolAccount1 LolAccount  @relation("DuoAccount1", fields: [lolAccountId1], references: [id])
  lolAccount2 LolAccount  @relation("DuoAccount2", fields: [lolAccountId2], references: [id])

  @@unique([guildServerId, lolAccountId1, lolAccountId2])
  @@map("duo_stat")
}

// ─────────────────────────────────────────
// 칭호 (서버별, 동적 — /전적갱신 시 재계산)
// ─────────────────────────────────────────

model UserTitle {
  id            BigInt   @id @default(autoincrement())
  lolAccountId  BigInt   @map("lol_account_id")
  guildServerId BigInt   @map("guild_server_id")
  titleCode     String   @map("title_code") @db.VarChar(50)
  statValue     Float?   @map("stat_value")
  updatedAt     DateTime @updatedAt @map("updated_at")

  lolAccount  LolAccount  @relation(fields: [lolAccountId], references: [id])
  guildServer GuildServer @relation(fields: [guildServerId], references: [id])

  @@unique([guildServerId, titleCode, lolAccountId])
  @@map("user_title")
}

// ─────────────────────────────────────────
// 업적
// ─────────────────────────────────────────

model Achievement {
  id          BigInt @id @default(autoincrement())
  code        String @unique @db.VarChar(50)
  name        String @db.VarChar(100)
  description String @db.VarChar(255)
  icon        String @db.VarChar(10)

  userAchievements UserAchievement[]

  @@map("achievement")
}

model UserAchievement {
  id            BigInt   @id @default(autoincrement())
  lolAccountId  BigInt   @map("lol_account_id")
  achievementId BigInt   @map("achievement_id")
  achievedAt    DateTime @default(now()) @map("achieved_at")

  lolAccount  LolAccount  @relation(fields: [lolAccountId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([lolAccountId, achievementId])
  @@map("user_achievement")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum TournamentCodeStatus {
  PENDING
  COMPLETED
  EXPIRED
}

enum Team {
  BLUE
  RED
}
